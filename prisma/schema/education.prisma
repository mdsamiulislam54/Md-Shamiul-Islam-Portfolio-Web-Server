model Education {
  id          String   @id @default(cuid())

  institute   String
  degree      String
  field       String

  startDate   DateTime?
  endDate     DateTime?

  cgpa        String?
  description String?  @db.Text

  logo        String?
  order       Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("education")
}

model Course {
  id           String   @id @default(cuid())

  title        String
  provider     String

  instructor   String?

  issueDate    DateTime?

  credential   String?

  image        String?
  imageId      String?

  skills       String[]

  description  String? @db.Text

  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("course")
}