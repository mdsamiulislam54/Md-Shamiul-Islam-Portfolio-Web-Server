model Skill {
  id          String   @id @default(cuid())

  name        String
  icon        String

  category    SkillCategory

  level       Int?      

  order       Int       @default(0)

  isPublished Boolean   @default(true)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

 enum SkillCategory {
  FRONTEND
  BACKEND
  DATABASE
  TOOLS
}